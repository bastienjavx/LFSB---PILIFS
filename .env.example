# Base de données PostgreSQL (fournie par Railway)
DATABASE_URL="postgresql://user:password@host:5432/pilifs"

# NextAuth - générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-app.railway.app"

# Compte admin initial (créé au premier démarrage via seed)
ADMIN_EMAIL="admin@pilifs.be"
ADMIN_PASSWORD="ChangeMe123!"

# Dossier uploads (Railway volume mounté ici)
UPLOAD_DIR="/app/public/uploads"

# URL publique des uploads
NEXT_PUBLIC_UPLOAD_URL="/uploads"
